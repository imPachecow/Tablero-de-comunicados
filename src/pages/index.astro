---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createSupabaseServerClient } from '../lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: groups } = await supabase
  .from('groups')
  .select('id, name, description')
  .order('name');
---

<BaseLayout title="Bienvenido" noChrome={true}>

  <!-- ════════════════════════════════════════════════════ -->
  <!-- PANTALLA DE INICIO — selección de perfil            -->
  <!-- ════════════════════════════════════════════════════ -->
  <div id="screen-landing" style="display:none"
    class="min-h-screen flex flex-col items-center justify-center px-6 py-16 bg-gray-50">

    <!-- Branding -->
    <div class="text-center mb-10 anim-enter">
      <div class="w-16 h-16 bg-primary-600 rounded-2xl flex items-center justify-center
                  mx-auto mb-5 shadow-lg shadow-primary-200">
        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M12 14l9-5-9-5-9 5 9 5z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
            d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055
               a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
        </svg>
      </div>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 tracking-tight">IE La Gabriela</h1>
      <p class="text-gray-500 mt-1.5 text-base leading-snug">Tablero de Comunicados</p>
    </div>

    <!-- Pregunta -->
    <p class="text-sm text-gray-400 mb-5 anim-enter-d1">¿Cómo quieres ingresar hoy?</p>

    <!-- Tarjetas de rol -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 w-full max-w-sm sm:max-w-md">

      <button id="btn-student"
        class="group flex flex-col items-center text-center p-7 bg-white rounded-2xl
               border-2 border-gray-100 hover:border-primary-300 hover:shadow-xl
               hover:shadow-primary-100 transition-all duration-200 cursor-pointer
               focus:outline-none focus:ring-2 focus:ring-primary-400 focus:ring-offset-2
               anim-enter-d2">
        <div class="w-14 h-14 bg-primary-50 group-hover:bg-primary-100 rounded-2xl
                    flex items-center justify-center mb-4 transition-colors duration-200">
          <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
              d="M12 14l9-5-9-5-9 5 9 5zm0 0v6" />
          </svg>
        </div>
        <span class="font-semibold text-gray-900 text-base mb-1">Soy Alumno</span>
        <span class="text-sm text-gray-400 leading-snug">Ver comunicados de mi grupo</span>
      </button>

      <button id="btn-teacher"
        class="group flex flex-col items-center text-center p-7 bg-white rounded-2xl
               border-2 border-gray-100 hover:border-gray-300 hover:shadow-xl
               hover:shadow-gray-100 transition-all duration-200 cursor-pointer
               focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2
               anim-enter-d3">
        <div class="w-14 h-14 bg-gray-100 group-hover:bg-gray-200 rounded-2xl
                    flex items-center justify-center mb-4 transition-colors duration-200">
          <svg class="w-7 h-7 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586
                 a1 1 0 01.707.293l5.414 5.414A1 1 0 0121 8.414V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <span class="font-semibold text-gray-900 text-base mb-1">Soy Docente</span>
        <span class="text-sm text-gray-400 leading-snug">Administrar grupos y anuncios</span>
      </button>

    </div>
  </div>

  <!-- ════════════════════════════════════════════════════ -->
  <!-- SELECTOR DE GRUPOS — vista alumno                   -->
  <!-- ════════════════════════════════════════════════════ -->
  <div id="screen-groups" style="display:none"
    class="min-h-screen bg-gray-50 px-4 sm:px-6 py-10 sm:py-14">
    <div class="max-w-4xl mx-auto">

      <!-- Header -->
      <div class="flex items-start justify-between mb-10 anim-enter">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-primary-600 rounded-xl flex items-center justify-center flex-shrink-0 shadow-md shadow-primary-200">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 14l9-5-9-5-9 5 9 5zm0 0v6" />
            </svg>
          </div>
          <div>
            <h1 class="text-xl sm:text-2xl font-bold text-gray-900 tracking-tight leading-none">
              Tablero de Comunicados
            </h1>
            <p class="text-sm text-gray-400 mt-1">Selecciona tu grupo para ver los comunicados.</p>
          </div>
        </div>
        <button id="btn-change-role"
          class="text-xs text-gray-400 hover:text-gray-700 transition-colors mt-1
                 underline underline-offset-2 flex-shrink-0 ml-4">
          Cambiar perfil
        </button>
      </div>

      <!-- Grid de grupos -->
      {(!groups || groups.length === 0) ? (
        <div class="text-center py-24 anim-enter-d1">
          <div class="w-14 h-14 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857
                   M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857
                   m0 0a5.002 5.002 0 019.288 0" />
            </svg>
          </div>
          <p class="text-gray-400 text-sm">No hay grupos disponibles aún.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="group-list">
          {groups.map((g, i) => (
            <a
              href={`/grupo/${g.id}`}
              data-group-id={g.id}
              class={`group bg-white rounded-xl border border-gray-100 p-5
                      hover:border-primary-200 hover:shadow-md transition-all cursor-pointer
                      anim-enter-d${Math.min(i + 1, 5)}`}
            >
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 bg-primary-50 rounded-xl flex items-center justify-center
                            flex-shrink-0 group-hover:bg-primary-100 transition-colors">
                  <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857
                         M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857
                         m0 0a5.002 5.002 0 019.288 0" />
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <h2 class="font-semibold text-gray-900 group-hover:text-primary-700
                             transition-colors leading-snug">
                    {g.name}
                  </h2>
                  {g.description && (
                    <p class="text-sm text-gray-500 mt-0.5 line-clamp-2">{g.description}</p>
                  )}
                </div>
                <svg class="w-4 h-4 text-gray-300 group-hover:text-primary-400 flex-shrink-0
                            mt-0.5 transition-colors"
                  fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      )}

    </div>
  </div>

</BaseLayout>

<script>
  const ROLE_KEY  = 'lg_role';
  const GROUP_KEY = 'lg_group';

  const $landing    = document.getElementById('screen-landing')!;
  const $groups     = document.getElementById('screen-groups')!;
  const $btnStudent = document.getElementById('btn-student');
  const $btnTeacher = document.getElementById('btn-teacher');
  const $btnChange  = document.getElementById('btn-change-role');

  function showLanding() {
    $groups.style.display  = 'none';
    $landing.style.display = '';
  }

  function showGroups() {
    $landing.style.display = 'none';
    $groups.style.display  = '';
  }

  // ── Routing inicial ────────────────────────────────────
  const savedRole  = localStorage.getItem(ROLE_KEY);
  const lastGroup  = localStorage.getItem(GROUP_KEY);

  if (savedRole === 'student') {
    if (lastGroup) {
      const exists = document.querySelector(`[data-group-id="${lastGroup}"]`);
      if (exists) {
        // Redirect silencioso al último grupo visitado
        window.location.replace(`/grupo/${lastGroup}`);
      } else {
        localStorage.removeItem(GROUP_KEY);
        showGroups();
      }
    } else {
      showGroups();
    }
  } else {
    // Sin rol guardado → mostrar landing
    showLanding();
  }

  // ── Botón: Soy Alumno ──────────────────────────────────
  $btnStudent?.addEventListener('click', () => {
    localStorage.setItem(ROLE_KEY, 'student');
    showGroups();
  });

  // ── Botón: Soy Docente ─────────────────────────────────
  // No guardamos 'teacher' en localStorage; la autenticación
  // Supabase es la fuente de verdad para los docentes.
  $btnTeacher?.addEventListener('click', () => {
    window.location.href = '/login';
  });

  // ── Botón: Cambiar perfil ──────────────────────────────
  $btnChange?.addEventListener('click', () => {
    localStorage.removeItem(ROLE_KEY);
    localStorage.removeItem(GROUP_KEY);
    showLanding();
  });
</script>
