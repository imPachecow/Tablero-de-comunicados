---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createSupabaseServerClient } from '../../lib/supabase';
import { requireTeacher, formatDate } from '../../lib/auth';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const result = await requireTeacher(supabase);
if ('redirect' in result) return Astro.redirect(result.redirect);
const { profile } = result;

type DashAnnouncement = {
  id: string;
  title: string;
  subtitle: string | null;
  group_ids: string[];
  pinned: boolean;
  created_at: string;
  attachments: { id: string }[];
};

const [{ data: groups }, { data: rawAnnouncements }] = await Promise.all([
  supabase
    .from('groups')
    .select('id, name, description')
    .eq('teacher_id', profile.id)
    .order('name'),
  supabase
    .from('announcements')
    .select('id, title, subtitle, group_ids, pinned, created_at, attachments:announcement_attachments(id)')
    .eq('teacher_id', profile.id)
    .order('created_at', { ascending: false })
    .limit(5),
]);

const announcements = (rawAnnouncements ?? []) as DashAnnouncement[];
const firstName = profile.full_name.split(' ')[0];
const hour = new Date().getHours();
const greeting = hour < 12 ? 'Buenos días' : hour < 19 ? 'Buenas tardes' : 'Buenas noches';
---

<BaseLayout title="Panel Docente" teacherNav={true} teacherName={profile.full_name}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">

    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900">{greeting}, {firstName}</h1>
      <p class="text-gray-500 mt-1">Resumen de tu tablero de comunicados.</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-8">
      <div class="card text-center">
        <p class="text-3xl font-bold text-primary-600 mb-1">{groups?.length ?? 0}</p>
        <p class="text-sm text-gray-500">Grupos</p>
      </div>
      <div class="card text-center">
        <p class="text-3xl font-bold text-primary-600 mb-1">{announcements.length}</p>
        <p class="text-sm text-gray-500">Anuncios recientes</p>
      </div>
      <div class="card text-center col-span-2 sm:col-span-1">
        <p class="text-3xl font-bold text-primary-600 mb-1">
          {announcements.filter(a => a.pinned).length}
        </p>
        <p class="text-sm text-gray-500">Destacados</p>
      </div>
    </div>

    <div class="flex flex-wrap gap-3 mb-8">
      <a href="/teacher/anuncios" class="btn-primary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Nuevo anuncio
      </a>
      <a href="/teacher/grupos" class="btn-secondary">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0" />
        </svg>
        Gestionar grupos
      </a>
    </div>

    <div>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-base font-semibold text-gray-900">Últimos anuncios</h2>
        <a href="/teacher/anuncios" class="text-sm text-primary-600 hover:text-primary-700 transition-colors">
          Ver todos →
        </a>
      </div>

      {announcements.length === 0 ? (
        <div class="card text-center py-12">
          <div class="w-12 h-12 bg-gray-100 rounded-xl flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
            </svg>
          </div>
          <p class="text-sm text-gray-400 mb-2">No has publicado anuncios aún.</p>
          <a href="/teacher/anuncios" class="text-sm text-primary-600 hover:underline">
            Publicar primer anuncio
          </a>
        </div>
      ) : (
        <div class="space-y-3">
          {announcements.map(ann => (
            <div class={`card hover:shadow-sm transition-all ${ann.pinned ? 'border-primary-100' : ''}`}>
              <div class="flex items-start justify-between gap-3">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap mb-0.5">
                    {ann.pinned && (
                      <span class="text-xs bg-primary-100 text-primary-700 px-2 py-0.5 rounded-full font-medium">
                        Destacado
                      </span>
                    )}
                    <h3 class="font-medium text-gray-900 text-sm truncate">{ann.title}</h3>
                  </div>
                  {ann.subtitle && (
                    <p class="text-xs text-gray-500 mb-1.5">{ann.subtitle}</p>
                  )}
                  <div class="flex items-center gap-3 text-xs text-gray-400 flex-wrap">
                    <span>{formatDate(ann.created_at)}</span>
                    <span>
                      {ann.group_ids.length} grupo{ann.group_ids.length !== 1 ? 's' : ''}
                    </span>
                    {ann.attachments.length > 0 && (
                      <span>
                        {ann.attachments.length} adjunto{ann.attachments.length !== 1 ? 's' : ''}
                      </span>
                    )}
                  </div>
                </div>
                <a href="/teacher/anuncios"
                  class="text-xs text-gray-400 hover:text-primary-600 transition-colors flex-shrink-0">
                  Gestionar
                </a>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

  </div>
</BaseLayout>
