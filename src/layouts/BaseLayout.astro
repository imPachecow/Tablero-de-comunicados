---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  teacherNav?: boolean;
  teacherName?: string;
  noChrome?: boolean; // oculta header y footer (para landing)
}

const { title = 'IE La Gabriela', teacherNav = false, teacherName, noChrome = false } = Astro.props;
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="es" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} — IE La Gabriela</title>
    <meta name="description" content="Tablero de comunicados — Institución Educativa La Gabriela" />
  </head>
  <body class="min-h-full bg-gray-50 font-sans text-gray-900 antialiased flex flex-col">

    {!noChrome && teacherNav ? (
      <nav class="bg-white border-b border-gray-200 sticky top-0 z-40">
        <div class="max-w-6xl mx-auto px-4 sm:px-6">
          <div class="flex items-center justify-between h-16 gap-4">

            <a href="/teacher/dashboard" class="flex items-center gap-2.5 flex-shrink-0 hover:opacity-80 transition-opacity">
              <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                    d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>
              <span class="font-semibold text-gray-900 text-sm hidden sm:block">IE La Gabriela</span>
            </a>

            <div class="flex items-center gap-0.5">
              <a href="/teacher/dashboard"
                class={`nav-link ${path === '/teacher/dashboard' ? 'active' : ''}`}>
                Panel
              </a>
              <a href="/teacher/grupos"
                class={`nav-link ${path === '/teacher/grupos' ? 'active' : ''}`}>
                Grupos
              </a>
              <a href="/teacher/anuncios"
                class={`nav-link ${path === '/teacher/anuncios' ? 'active' : ''}`}>
                Anuncios
              </a>
            </div>

            <div class="flex items-center gap-3 flex-shrink-0">
              {teacherName && (
                <span class="text-sm text-gray-500 hidden md:block">{teacherName}</span>
              )}
              <form method="POST" action="/api/auth/logout">
                <button type="submit"
                  class="text-sm text-gray-500 hover:text-red-600 transition-colors px-3 py-1.5 rounded-md hover:bg-red-50">
                  Salir
                </button>
              </form>
            </div>

          </div>
        </div>
      </nav>
    ) : !noChrome ? (
      <header class="bg-white border-b border-gray-100">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 py-4 flex items-center gap-3">
          <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900 text-sm leading-none">IE La Gabriela</p>
            <p class="text-xs text-gray-400 mt-0.5">Tablero de comunicados</p>
          </div>
        </div>
      </header>
    ) : null}

    <main class="flex-1">
      <slot />
    </main>

    {!noChrome && (
      <footer class="border-t border-gray-100 bg-white mt-auto">
        <div class="max-w-6xl mx-auto px-4 py-4 text-center text-xs text-gray-400">
          Institución Educativa La Gabriela &mdash; Área de Tecnología
        </div>
      </footer>
    )}

    <Analytics />
  </body>
</html>
