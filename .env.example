# ══════════════════════════════════════════════════
# Variables de entorno — IE La Gabriela
# Copia este archivo como .env y completa los valores
# ══════════════════════════════════════════════════

# URL del proyecto Supabase (visible en Project Settings → API)
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anónima pública (visible en Project Settings → API)
PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clave de servicio (solo para scripts de administración — NUNCA exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
